<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>io.reticle.app</string>
    <key>CFBundleName</key>
    <string>Reticle</string>
    <key>CFBundleDisplayName</key>
    <string>Reticle</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <!-- 독 아이콘 숨김 (setActivationPolicy와 동일 효과, 번들 레벨에서 선언) -->
    <key>LSUIElement</key>
    <true/>
    <!-- Retina 지원 -->
    <key>NSHighResolutionCapable</key>
    <true/>
    <!-- Screen Recording 권한 설명 (시스템 다이얼로그에 표시됨) -->
    <key>NSScreenCaptureUsageDescription</key>
    <string>Reticle needs Screen Recording access to take screenshots.</string>
</dict>
</plist>
