---
const base = import.meta.env.BASE_URL;
---
<footer class="border-t border-surface-border mt-32">
  <div class="max-w-5xl mx-auto px-6 py-12 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-text-secondary">
    <span>© 2026 croc100 — <a href="https://github.com/croc100/Reticle/blob/main/LICENSE" class="hover:text-text-primary transition-colors">Source Available</a></span>
    <div class="flex items-center gap-6">
      <a href="https://github.com/croc100/Reticle" class="hover:text-text-primary transition-colors">GitHub</a>
      <a href={`${base}changelog/`} class="hover:text-text-primary transition-colors">Changelog</a>
      <a href={`${base}docs/`} class="hover:text-text-primary transition-colors">Docs</a>
      <a href={`${base}sponsor/`} class="hover:text-accent transition-colors">Sponsor</a>
    </div>
  </div>
</footer>
