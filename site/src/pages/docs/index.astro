---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const base = import.meta.env.BASE_URL;

const cards = [
  {
    icon: '🚀',
    title: 'Getting Started',
    desc: 'Install Reticle on your Mac and take your first screenshot — no GitHub account needed.',
    href: `${base}docs/getting-started/`,
    cta: 'Start here →',
    highlight: true,
  },
  {
    icon: '🔐',
    title: 'Permissions',
    desc: 'Grant Screen Recording and Accessibility — required for Reticle to work.',
    href: `${base}docs/permissions/`,
    cta: 'Read more →',
  },
  {
    icon: '📸',
    title: 'Capture Modes',
    desc: 'Region, full-screen, window, scroll, auto-capture — all the ways to grab your screen.',
    href: `${base}docs/capture/`,
    cta: 'Read more →',
  },
  {
    icon: '✏️',
    title: 'Annotation Tools',
    desc: '21 tools — shapes, text, blur, highlight, arrows, step numbers and more.',
    href: `${base}docs/annotate/`,
    cta: 'Read more →',
  },
  {
    icon: '⚡',
    title: 'After Capture',
    desc: 'Copy to clipboard, save to file, OCR, pin to screen, open in viewer.',
    href: `${base}docs/after-capture/`,
    cta: 'Read more →',
  },
  {
    icon: '☁️',
    title: 'Uploads',
    desc: 'Imgur, Amazon S3, SFTP, and custom HTTP endpoints.',
    href: `${base}docs/uploads/`,
    cta: 'Read more →',
  },
  {
    icon: '⌨️',
    title: 'Hotkeys',
    desc: 'Set global keyboard shortcuts for every capture mode and workflow.',
    href: `${base}docs/hotkeys/`,
    cta: 'Read more →',
  },
  {
    icon: '🔗',
    title: 'Workflows',
    desc: 'Chain capture → annotate → upload into one-key automations.',
    href: `${base}docs/workflows/`,
    cta: 'Read more →',
  },
  {
    icon: '🛠',
    title: 'Custom Uploader',
    desc: 'Wire up any HTTP API as an upload destination with a simple JSON config.',
    href: `${base}docs/uploaders/`,
    cta: 'Read more →',
  },
];
---

<BaseLayout title="Docs — Reticle">
  <Header active="docs" />

  <div class="max-w-5xl mx-auto px-6 pt-28 pb-24">
    <h1 class="text-4xl font-bold mb-2">Documentation</h1>
    <p class="text-text-secondary mb-12 text-lg">
      Everything you need to get up and running with Reticle.
      <br class="hidden sm:block"/>
      <span class="text-sm">New here? Start with <a href={`${base}docs/getting-started/`} class="text-accent hover:underline">Getting Started</a>.</span>
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {cards.map(card => (
        <a
          href={card.href}
          class={`group flex flex-col gap-3 p-5 rounded-xl border transition-all ${
            card.highlight
              ? 'border-accent/40 bg-accent/5 hover:bg-accent/10'
              : 'border-surface-border bg-surface-raised hover:border-text-secondary/30'
          }`}
        >
          <div class="text-2xl">{card.icon}</div>
          <div>
            <div class={`font-semibold mb-1 ${card.highlight ? 'text-accent' : 'text-text-primary'}`}>
              {card.title}
            </div>
            <div class="text-sm text-text-secondary leading-relaxed">{card.desc}</div>
          </div>
          <div class={`text-sm mt-auto ${card.highlight ? 'text-accent' : 'text-text-secondary group-hover:text-text-primary'} transition-colors`}>
            {card.cta}
          </div>
        </a>
      ))}
    </div>
  </div>

  <Footer />
</BaseLayout>
